{
  "name": "haru-calendar-desktop",
  "version": "0.8.1",
  "description": "HARU Windows 데스크톱 캘린더 앱",
  "main": "main.cjs",
  "author": "heesunghwang",
  "license": "MIT",
  "scripts": {
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.haru.calendar.desktop",
    "productName": "HARU",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "index.html",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "artifactName": "HARU-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HARU"
    }
  }
}
